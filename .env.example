# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_db

# ── Elasticsearch ───────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=legal_chunks

# ── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=legal_chunks
QDRANT_VECTOR_DIM=1024

# ── LLM (OpenAI-compatible) ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional: override base URL for Gemini or other OpenAI-compatible endpoints
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gpt-4o-mini

# ── Optional: use LLM for query date extraction (slower but more accurate) ──
USE_LLM_EXTRACTOR=false

# ── FastAPI server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=false
